    "release": "electron-builder"
  },
  "dependencies": {
    "@snaplink/shared-types": "*",
    "chokidar": "^3.6.0",
    "electron-store": "^8.2.0",
    "keytar": "^7.9.0",
    "electron-updater": "^6.2.0",
    "form-data": "^4.0.0",
    "axios": "^1.7.0",
    "zustand": "^4.5.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/node": "^20.14.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "electron": "^30.1.0",
    "electron-builder": "^24.13.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.0",
    "vite": "^5.3.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.5"
  }
