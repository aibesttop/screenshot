---
import Base from "../layouts/Base.astro";
import DownloadButtons from "../components/DownloadButtons.astro";

const features = [
  {
    title: "Drops to the clipboard",
    body: "The URL is on your clipboard before your screenshot tool finishes its shutter animation. Paste into Claude, ChatGPT, or Cursor without breaking flow.",
  },
  {
    title: "OCR ships with every link",
    body: "Every image is run through Tesseract. Append .txt to any link to get plain text — perfect for pasting code snippets or error messages to an LLM.",
  },
  {
    title: "Burn after read",
    body: "One-time view links that delete themselves after the first GET. Ideal for sharing screenshots of production data with a colleague.",
  },
  {
    title: "Short URLs, real domain",
    body: "snp.ink/ab12cd — 14 characters including the scheme. Your prompts stay readable and your context window stays tight.",
  },
  {
    title: "Works offline-first",
    body: "Watches your screenshot folder in the background. If the network drops, uploads queue and retry. You never lose a screenshot.",
  },
  {
    title: "MCP server built-in",
    body: "Expose snaplink_list and snaplink_search_text as Model Context Protocol tools. Claude Desktop can query your screenshot history directly.",
  },
];

const howItWorks = [
  {
    step: "01",
    title: "Take a screenshot",
    body: "Keep using Cmd+Shift+4 on Mac, Win+Shift+S on Windows, or your favorite tool on Linux. SnapLink watches your screenshot folder in the background.",
  },
  {
    step: "02",
    title: "URL is on your clipboard",
    body: "In under 500ms, the image is uploaded, OCR'd, shortened, and copied. A subtle toast confirms the URL is ready.",
  },
  {
    step: "03",
    title: "Paste into your AI",
    body: "Claude, ChatGPT, Cursor, and Windsurf all fetch the image on their end. Append .txt to the URL to get OCR text in the same turn.",
  },
];

const ai = [
  {
    name: "Claude",
    line: "Paste the URL directly. Claude fetches the image and reads OCR text in the same turn.",
  },
  {
    name: "ChatGPT",
    line: "Vision mode accepts SnapLink URLs without an extra download step.",
  },
  {
    name: "Cursor",
    line: "Attach a URL to a chat or an inline edit. Cursor pulls the image and passes it to your selected model.",
  },
];

const comparison = [
  {
    feature: "Clipboard is the URL, not the image",
    snaplink: true,
    imgur: false,
    cleanshot: true,
    dropshare: true,
  },
  {
    feature: "OCR embedded in every upload",
    snaplink: true,
    imgur: false,
    cleanshot: false,
    dropshare: false,
  },
  {
    feature: "Designed for LLM prompts",
    snaplink: true,
    imgur: false,
    cleanshot: false,
    dropshare: false,
  },
  {
    feature: "Burn-after-read links",
    snaplink: true,
    imgur: false,
    cleanshot: false,
    dropshare: false,
  },
  {
    feature: "MCP server for Claude/Cursor",
    snaplink: true,
    imgur: false,
    cleanshot: false,
    dropshare: false,
  },
  {
    feature: "Works on Mac, Windows, Linux",
    snaplink: true,
    imgur: true,
    cleanshot: false,
    dropshare: false,
  },
  {
    feature: "Free tier",
    snaplink: "100 / mo",
    imgur: "Yes",
    cleanshot: "No",
    dropshare: "No",
  },
];

const pricing = [
  {
    name: "Free",
    price: "$0",
    tagline: "For casual use",
    items: [
      "100 uploads / month",
      "OCR on every upload",
      "7-day retention",
      "snp.ink domain",
    ],
    cta: "Download",
    href: "#download",
    highlight: false,
  },
  {
    name: "Pro",
    price: "$5",
    tagline: "For daily AI workflow users",
    items: [
      "Unlimited uploads",
      "Custom retention (forever, 30d, 7d, 1d, 1h)",
      "Priority OCR queue",
      "Custom domain (yours.com)",
    ],
    cta: "Start free 14-day trial",
    href: "/pricing",
    highlight: true,
  },
  {
    name: "Team",
    price: "$12",
    tagline: "Per seat, for shared workspaces",
    items: [
      "Everything in Pro",
      "Shared project spaces",
      "SAML SSO (coming soon)",
      "Audit log",
    ],
    cta: "Talk to us",
    href: "/pricing",
    highlight: false,
  },
];

const faqs = [
  {
    q: "Does SnapLink upload every screenshot I take?",
    a: "Only ones that look like screenshots — filtered by filename pattern, file size, and recency. You can pause it any time from the tray, and the watched folders are fully configurable.",
  },
  {
    q: "Where do my images go?",
    a: "Cloudflare R2, behind Cloudflare's CDN. EXIF data is stripped before upload. You can set per-upload expiry or enable burn-after-read so links delete themselves.",
  },
  {
    q: "Do I need an account to use it?",
    a: "No — the free tier works without an account for light use. An account unlocks history across devices and upload limits.",
  },
  {
    q: "Is there a self-hosted option?",
    a: "Team plan includes a self-hosted backend Docker image. Enterprise plan includes on-prem support and SAML.",
  },
  {
    q: "Why short URLs instead of a data URI?",
    a: "Data URIs blow up your prompt context. A 14-char URL uses ~5 tokens instead of thousands, and Claude/ChatGPT fetch the image on their end anyway.",
  },
];
---

<Base>
  <!-- ═══════════════ Hero ═══════════════ -->
  <section id="download" class="max-w-6xl mx-auto px-5 pt-20 pb-20">
    <div class="max-w-3xl">
      <div class="inline-flex items-center gap-2 text-xs text-brand bg-brand/10 border border-brand/30 rounded-full px-3 py-1 mb-6">
        <span class="w-1.5 h-1.5 rounded-full bg-brand animate-pulse"></span>
        Now in public beta
      </div>
      <h1 class="text-5xl sm:text-6xl font-semibold tracking-tight text-white">
        Drop a screenshot.<br />
        <span class="text-brand">Get a short URL.</span>
      </h1>
      <p class="mt-6 text-xl text-ink-300 leading-relaxed">
        SnapLink watches your screenshot folder and turns every capture into a
        short, shareable URL with OCR built-in — designed for pasting into
        Claude, ChatGPT, and Cursor.
      </p>
      <div class="mt-10">
        <DownloadButtons size="lg" />
      </div>
      <p class="mt-4 text-sm text-ink-500">
        Free forever for 100 screenshots / month · Pro $5 / mo · No credit card to start
      </p>
    </div>

    <!-- Terminal mock -->
    <div class="mt-16 rounded-xl border border-ink-800 bg-ink-900/60 p-6 shadow-2xl shadow-black/40">
      <div class="flex items-center gap-1.5 mb-4">
        <span class="w-3 h-3 rounded-full bg-red-500/80"></span>
        <span class="w-3 h-3 rounded-full bg-yellow-500/80"></span>
        <span class="w-3 h-3 rounded-full bg-green-500/80"></span>
        <span class="ml-3 text-xs text-ink-500">~ snaplink ~</span>
      </div>
      <pre class="m-0 border-0 bg-transparent p-0 text-ink-200"><code>{`# You press Cmd+Shift+4 and snip a region.
# A second later:

✓ screenshot-2026-04-14.png uploaded  (287ms)
  → https://snp.ink/a7Xc9f2   (copied to clipboard)
  → OCR: "TypeError: Cannot read property 'length' of undefined"

# Paste into Claude:
#   https://snp.ink/a7Xc9f2
# Claude sees the image AND the OCR text.`}</code></pre>
    </div>
  </section>

  <!-- ═══════════════ How it works ═══════════════ -->
  <section class="max-w-6xl mx-auto px-5 py-16">
    <div class="text-center mb-14">
      <div class="text-xs uppercase tracking-wider text-brand font-semibold mb-3">How it works</div>
      <h2 class="text-3xl sm:text-4xl font-semibold text-white">
        Three steps. No new habits to learn.
      </h2>
    </div>
    <div class="grid gap-6 md:grid-cols-3">
      {
        howItWorks.map((s) => (
          <div class="relative rounded-xl border border-ink-800 bg-ink-900/40 p-6">
            <div class="text-5xl font-bold text-brand/30 leading-none mb-4">{s.step}</div>
            <div class="text-white font-semibold text-lg mb-2">{s.title}</div>
            <p class="text-ink-300 text-sm leading-relaxed">{s.body}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- ═══════════════ Features ═══════════════ -->
  <section class="max-w-6xl mx-auto px-5 py-16">
    <h2 class="text-3xl font-semibold text-white mb-2">Built for AI-assisted workflows</h2>
    <p class="text-ink-300 max-w-2xl">
      Generic image hosts weren't designed for prompts. SnapLink is.
    </p>
    <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        features.map((f) => (
          <div class="rounded-lg border border-ink-800 bg-ink-900/40 p-5 hover:border-ink-700 transition-colors">
            <div class="text-white font-semibold mb-2">{f.title}</div>
            <p class="text-ink-300 leading-relaxed text-sm">{f.body}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- ═══════════════ AI integrations with MCP config ═══════════════ -->
  <section class="max-w-6xl mx-auto px-5 py-16">
    <h2 class="text-3xl font-semibold text-white mb-2">Works with the tools you already use</h2>
    <p class="text-ink-300 max-w-2xl">
      Paste a SnapLink URL anywhere that accepts images. For Claude Desktop and
      Cursor, add our MCP server to query your screenshot history directly.
    </p>
    <div class="mt-10 grid gap-6 lg:grid-cols-5">
      <div class="lg:col-span-2 grid gap-4">
        {
          ai.map((x) => (
            <div class="rounded-lg border border-ink-800 p-5">
              <div class="text-white font-semibold mb-2">{x.name}</div>
              <p class="text-ink-300 text-sm leading-relaxed">{x.line}</p>
            </div>
          ))
        }
      </div>
      <div class="lg:col-span-3 rounded-xl border border-ink-800 bg-ink-900/60 p-6">
        <div class="flex items-center justify-between mb-4">
          <div class="text-xs text-ink-400">
            <span class="text-ink-500">~/.claude/</span>config.json
          </div>
          <div class="text-xs text-ink-500">MCP</div>
        </div>
        <pre class="m-0 border-0 bg-transparent p-0 text-sm text-ink-200"><code>{`{
  "mcpServers": {
    "snaplink": {
      "command": "npx",
      "args": ["-y", "snaplink-mcp"],
      "env": {
        "SNAPLINK_TOKEN": "\${SNAPLINK_TOKEN}"
      }
    }
  }
}`}</code></pre>
        <p class="mt-4 text-xs text-ink-400">
          Claude and Cursor can now call <code>snaplink_list</code> and <code>snaplink_search_text</code>
          to look through your recent screenshots.
          <a href="/docs/mcp" class="text-brand">Docs →</a>
        </p>
      </div>
    </div>
  </section>

  <!-- ═══════════════ Comparison ═══════════════ -->
  <section class="max-w-6xl mx-auto px-5 py-16">
    <h2 class="text-3xl font-semibold text-white mb-2">How SnapLink compares</h2>
    <p class="text-ink-300 max-w-2xl">
      We're not trying to be Imgur, CleanShot, or Dropshare. We're trying to be
      the fastest path from screenshot to AI context.
    </p>
    <div class="mt-10 overflow-x-auto rounded-xl border border-ink-800">
      <table class="w-full text-sm">
        <thead class="bg-ink-900/60 text-ink-400">
          <tr>
            <th class="text-left font-medium px-5 py-3 border-b border-ink-800">Feature</th>
            <th class="text-center font-medium px-5 py-3 border-b border-ink-800 text-brand">SnapLink</th>
            <th class="text-center font-medium px-5 py-3 border-b border-ink-800">Imgur</th>
            <th class="text-center font-medium px-5 py-3 border-b border-ink-800">CleanShot X</th>
            <th class="text-center font-medium px-5 py-3 border-b border-ink-800">Dropshare</th>
          </tr>
        </thead>
        <tbody>
          {
            comparison.map((row) => (
              <tr class="border-b border-ink-800 last:border-0">
                <td class="px-5 py-3 text-ink-200">{row.feature}</td>
                <td class="px-5 py-3 text-center text-white font-medium">
                  {typeof row.snaplink === "boolean"
                    ? row.snaplink
                      ? "✓"
                      : "—"
                    : row.snaplink}
                </td>
                <td class="px-5 py-3 text-center text-ink-400">
                  {typeof row.imgur === "boolean" ? (row.imgur ? "✓" : "—") : row.imgur}
                </td>
                <td class="px-5 py-3 text-center text-ink-400">
                  {typeof row.cleanshot === "boolean"
                    ? row.cleanshot
                      ? "✓"
                      : "—"
                    : row.cleanshot}
                </td>
                <td class="px-5 py-3 text-center text-ink-400">
                  {typeof row.dropshare === "boolean"
                    ? row.dropshare
                      ? "✓"
                      : "—"
                    : row.dropshare}
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </section>

  <!-- ═══════════════ Pricing teaser ═══════════════ -->
  <section class="max-w-6xl mx-auto px-5 py-16">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-semibold text-white mb-3">Simple pricing</h2>
      <p class="text-ink-300 max-w-2xl mx-auto">
        Free tier is genuinely usable. Pro pays for itself if you paste one
        screenshot into an AI every weekday.
      </p>
    </div>
    <div class="grid gap-6 md:grid-cols-3">
      {
        pricing.map((p) => (
          <div
            class:list={[
              "rounded-xl border p-6 flex flex-col",
              p.highlight
                ? "border-brand bg-brand/5 relative"
                : "border-ink-800 bg-ink-900/40",
            ]}
          >
            {p.highlight && (
              <div class="absolute -top-3 left-6 text-[10px] uppercase tracking-wider text-white bg-brand px-2 py-1 rounded">
                Most popular
              </div>
            )}
            <div class="text-white font-semibold text-lg">{p.name}</div>
            <div class="text-ink-400 text-sm mb-4">{p.tagline}</div>
            <div class="text-4xl font-bold text-white mb-1">
              {p.price}
              <span class="text-base font-normal text-ink-400"> / month</span>
            </div>
            <ul class="mt-6 space-y-2 flex-1">
              {
                p.items.map((item) => (
                  <li class="text-sm text-ink-200 flex gap-2">
                    <span class="text-brand mt-0.5">✓</span>
                    <span>{item}</span>
                  </li>
                ))
              }
            </ul>
            <a
              href={p.href}
              class:list={[
                "mt-6 no-underline text-center rounded-lg px-4 py-2.5 text-sm font-medium",
                p.highlight
                  ? "bg-brand hover:bg-brand-600 text-white"
                  : "border border-ink-700 hover:border-ink-500 text-white",
              ]}
            >
              {p.cta}
            </a>
          </div>
        ))
      }
    </div>
    <div class="text-center mt-8">
      <a href="/pricing" class="text-brand no-underline text-sm">
        Compare all features and limits →
      </a>
    </div>
  </section>

  <!-- ═══════════════ FAQ ═══════════════ -->
  <section class="max-w-3xl mx-auto px-5 py-16">
    <h2 class="text-3xl font-semibold text-white text-center mb-2">
      Frequently asked
    </h2>
    <p class="text-ink-300 text-center mb-12">
      Didn't find your question? <a href="/support" class="text-brand">Ask us</a>.
    </p>
    <div class="space-y-3">
      {
        faqs.map((f) => (
          <details class="group rounded-lg border border-ink-800 bg-ink-900/40 p-5 open:bg-ink-900/70">
            <summary class="cursor-pointer list-none flex justify-between items-center text-white font-medium select-none">
              <span>{f.q}</span>
              <span class="text-ink-400 transition-transform group-open:rotate-45 text-xl leading-none">+</span>
            </summary>
            <p class="mt-3 text-ink-300 text-sm leading-relaxed">{f.a}</p>
          </details>
        ))
      }
    </div>
  </section>

  <!-- ═══════════════ Privacy ═══════════════ -->
  <section class="max-w-6xl mx-auto px-5 py-16">
    <div class="rounded-xl border border-ink-800 bg-gradient-to-br from-ink-900 to-ink-950 p-10">
      <div class="grid gap-8 md:grid-cols-2 items-center">
        <div>
          <div class="text-xs uppercase tracking-wider text-brand font-semibold mb-3">
            Privacy
          </div>
          <h2 class="text-3xl font-semibold text-white">Private by default</h2>
          <p class="mt-3 text-ink-300">
            EXIF data is stripped on every upload. Burn-after-read links
            disappear after the first view. You can set a default expiration —
            1 hour, 1 day, 7 days, 30 days, or never — per screenshot. No
            trackers, no analytics unless you opt in.
          </p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a href="/legal/privacy" class="no-underline rounded-lg border border-ink-700 hover:border-ink-500 text-white px-4 py-2 text-sm">
              Privacy Policy
            </a>
            <a href="/docs/configuration" class="no-underline rounded-lg border border-ink-700 hover:border-ink-500 text-white px-4 py-2 text-sm">
              Privacy settings
            </a>
          </div>
        </div>
        <ul class="grid gap-3 text-sm text-ink-200">
          <li class="flex gap-3 items-start">
            <span class="text-brand mt-0.5">●</span>
            <span>EXIF metadata stripped before upload</span>
          </li>
          <li class="flex gap-3 items-start">
            <span class="text-brand mt-0.5">●</span>
            <span>Device tokens stored in your OS keychain, never on disk</span>
          </li>
          <li class="flex gap-3 items-start">
            <span class="text-brand mt-0.5">●</span>
            <span>Images hosted on Cloudflare R2 — no egress billing for you</span>
          </li>
          <li class="flex gap-3 items-start">
            <span class="text-brand mt-0.5">●</span>
            <span>No trackers in the app. Telemetry is off by default.</span>
          </li>
          <li class="flex gap-3 items-start">
            <span class="text-brand mt-0.5">●</span>
            <span>One-click delete from the app, with CDN purge</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ═══════════════ Final CTA ═══════════════ -->
  <section class="max-w-6xl mx-auto px-5 py-20 text-center">
    <h2 class="text-4xl font-semibold text-white">
      Your next screenshot is already a URL.
    </h2>
    <p class="mt-4 text-ink-300 max-w-2xl mx-auto">
      Install SnapLink and stop right-click → copy image address.
    </p>
    <div class="mt-8 flex justify-center">
      <DownloadButtons size="lg" />
    </div>
    <p class="mt-4 text-sm text-ink-500">
      Open source · Mac, Windows, Linux · No account required for free tier
    </p>
  </section>
</Base>
