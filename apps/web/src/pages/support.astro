---
import Base from "../layouts/Base.astro";

const channels = [
  {
    name: "Email support",
    desc: "For account, billing, and bug reports. We reply within 24 business hours (Pro) or 1 business week (Free).",
    cta: { label: "support@snaplink.io", href: "mailto:support@snaplink.io" },
  },
  {
    name: "Security reports",
    desc: "Disclose vulnerabilities privately. PGP fingerprint in the Privacy Policy.",
    cta: { label: "security@snaplink.io", href: "mailto:security@snaplink.io" },
  },
  {
    name: "Billing",
    desc: "Refunds, invoices, tax forms, or subscription changes.",
    cta: { label: "billing@snaplink.io", href: "mailto:billing@snaplink.io" },
  },
  {
    name: "Content takedowns / DMCA",
    desc: "Report infringing or illegal content hosted on snp.ink.",
    cta: { label: "dmca@snaplink.io", href: "mailto:dmca@snaplink.io" },
  },
  {
    name: "GitHub Issues",
    desc: "Open a public issue for bugs, feature requests, or integration problems.",
    cta: { label: "aibesttop/screenshot", href: "https://github.com/aibesttop/screenshot/issues" },
  },
  {
    name: "Status page",
    desc: "Live uptime + incident history for api.snaplink.io and snp.ink.",
    cta: { label: "status.snaplink.io", href: "https://status.snaplink.io" },
  },
];
---

<Base
  title="Support — SnapLink"
  description="Get help with SnapLink. Email support, security reports, billing inquiries, and the beta feedback form."
>
  <section class="max-w-4xl mx-auto px-5 py-14">
    <h1 class="text-4xl font-semibold text-white">Support</h1>
    <p class="mt-3 text-ink-300 text-lg max-w-2xl">
      We read everything. Pick the channel that best matches what you need.
    </p>
  </section>

  <section class="max-w-4xl mx-auto px-5 pb-10">
    <div class="grid gap-4 md:grid-cols-2">
      {
        channels.map((c) => (
          <div class="rounded-lg border border-ink-800 bg-ink-900/40 p-5">
            <div class="text-white font-semibold mb-1">{c.name}</div>
            <p class="text-ink-300 text-sm leading-relaxed mb-3">{c.desc}</p>
            <a
              href={c.cta.href}
              class="no-underline text-brand text-sm hover:text-brand-600 break-all"
            >
              {c.cta.label}
            </a>
          </div>
        ))
      }
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-5 py-10">
    <h2 class="text-2xl font-semibold text-white mb-4">Beta feedback form</h2>
    <p class="text-ink-300 text-sm mb-6 max-w-2xl">
      In a hurry? You can also send feedback from inside the desktop app
      (Settings → Account → Send feedback) — it's faster because it includes
      diagnostics automatically.
    </p>
    <form
      id="feedback-form"
      class="space-y-4 rounded-xl border border-ink-800 bg-ink-900/40 p-6"
      novalidate
    >
      <div class="grid gap-4 sm:grid-cols-2">
        <label class="block">
          <span class="text-sm text-ink-200">Category</span>
          <select
            name="category"
            class="mt-1 block w-full bg-ink-800 text-ink-100 text-sm rounded px-3 py-2 border border-ink-700 focus:border-brand focus:outline-none"
          >
            <option value="bug">Bug report</option>
            <option value="feature">Feature request</option>
            <option value="question">Question</option>
            <option value="other">Other</option>
          </select>
        </label>
        <label class="block">
          <span class="text-sm text-ink-200">Email (optional)</span>
          <input
            type="email"
            name="email"
            placeholder="you@domain.com"
            class="mt-1 block w-full bg-ink-800 text-ink-100 text-sm rounded px-3 py-2 border border-ink-700 focus:border-brand focus:outline-none"
          />
        </label>
      </div>
      <label class="block">
        <span class="text-sm text-ink-200">Message</span>
        <textarea
          name="message"
          required
          minlength="5"
          maxlength="5000"
          rows="6"
          placeholder="Describe the issue, feature, or question. Include steps to reproduce if it's a bug."
          class="mt-1 block w-full bg-ink-800 text-ink-100 text-sm rounded px-3 py-2 border border-ink-700 focus:border-brand focus:outline-none resize-y"
        ></textarea>
      </label>
      <div
        id="feedback-status"
        class="hidden text-sm rounded-lg px-3 py-2 border"
      >
      </div>
      <div class="flex items-center justify-between">
        <p class="text-xs text-ink-500">
          We don't share feedback with third parties. See the
          <a href="/legal/privacy" class="no-underline">Privacy Policy</a>.
        </p>
        <button
          type="submit"
          class="rounded-lg bg-brand hover:bg-brand-600 text-white text-sm font-medium px-4 py-2"
        >
          Send feedback
        </button>
      </div>
    </form>

    <script is:inline>
      (function () {
        const API_URL =
          (typeof window !== "undefined" && window.__SNAPLINK_API_URL__) ||
          "https://api.snaplink.io";
        const form = document.getElementById("feedback-form");
        const status = document.getElementById("feedback-status");
        if (!form || !status) return;

        function setStatus(kind, text) {
          status.textContent = text;
          status.classList.remove(
            "hidden",
            "text-red-300",
            "bg-red-900/30",
            "border-red-800",
            "text-green-300",
            "bg-green-900/30",
            "border-green-800"
          );
          if (kind === "ok") {
            status.classList.add(
              "text-green-300",
              "bg-green-900/30",
              "border-green-800"
            );
          } else {
            status.classList.add(
              "text-red-300",
              "bg-red-900/30",
              "border-red-800"
            );
          }
        }

        form.addEventListener("submit", async function (e) {
          e.preventDefault();
          const data = new FormData(form);
          const message = (data.get("message") || "").toString().trim();
          if (message.length < 5) {
            setStatus("err", "Message must be at least 5 characters.");
            return;
          }
          const btn = form.querySelector("button[type=submit]");
          if (btn) {
            btn.disabled = true;
            btn.textContent = "Sending...";
          }
          try {
            const res = await fetch(API_URL + "/api/v1/feedback", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({
                category: data.get("category") || "other",
                email: data.get("email") || null,
                message: message,
              }),
            });
            if (!res.ok) {
              const body = await res.json().catch(() => ({}));
              throw new Error(body.message || "Failed (" + res.status + ")");
            }
            setStatus("ok", "Thanks — we got it.");
            form.reset();
          } catch (err) {
            setStatus("err", (err && err.message) || "Request failed");
          } finally {
            if (btn) {
              btn.disabled = false;
              btn.textContent = "Send feedback";
            }
          }
        });
      })();
    </script>
  </section>

  <section class="max-w-4xl mx-auto px-5 py-10">
    <h2 class="text-2xl font-semibold text-white mb-3">Response times</h2>
    <ul class="text-ink-200 text-sm space-y-2">
      <li><span class="text-white font-medium">Pro / Team</span>: 24 business hours, Monday–Friday.</li>
      <li><span class="text-white font-medium">Free</span>: best-effort, typically within a week.</li>
      <li><span class="text-white font-medium">Security</span>: triaged same day. Critical issues are acknowledged within 4 hours.</li>
      <li><span class="text-white font-medium">Incidents</span>: live updates on <a href="https://status.snaplink.io">status.snaplink.io</a>.</li>
    </ul>
  </section>
</Base>
